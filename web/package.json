'use client'
import { useState } from 'react'

function usePost(path: string) {
  const [answer, setAnswer] = useState('')
  const [loading, setLoading] = useState(false)
  async function ask(q: string) {
    setLoading(true)
    setAnswer('')
    try {
      const res = await fetch(path, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ q })
      })
      const json = await res.json()
      setAnswer(json.answer || 'Ready')
    } catch {
      setAnswer('Error')
    } finally {
      setLoading(false)
    }
  }
  return { ask, answer, loading }
}

export function HelpBot() {
  const { ask, answer, loading } = usePost('/api/proxy/bot/help')
  const [q, setQ] = useState('')
  return (
    <div className="card p-5">
      <div className="font-medium">Help bot</div>
      <form onSubmit={e => { e.preventDefault(); ask(q) }} className="mt-3 grid gap-2">
        <input className="border rounded-xl px-3 py-2" value={q} onChange={e => setQ(e.target.value)} placeholder="Ask a question" />
        <button className="btn-primary" disabled={loading}>{loading ? '...' : 'Ask'}</button>
      </form>
      {answer && <div className="mt-3 text-slate-700 whitespace-pre-wrap">{answer}</div>}
    </div>
  )
}

export function GriefBot() {
  const { ask, answer, loading } = usePost('/api/proxy/bot/grief')
  const [q, setQ] = useState('')
  return (
    <div className="card p-5">
      <div className="font-medium">Grief support</div>
      <form onSubmit={e => { e.preventDefault(); ask(q) }} className="mt-3 grid gap-2">
        <input className="border rounded-xl px-3 py-2" value={q} onChange={e => setQ(e.target.value)} placeholder="Share how you feel" />
        <button className="btn-primary" disabled={loading}>{loading ? '...' : 'Send'}</button>
      </form>
      {answer && <div className="mt-3 text-slate-700 whitespace-pre-wrap">{answer}</div>}
    </div>
  )
}

