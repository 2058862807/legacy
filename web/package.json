// -----------------------------
import { getServerSession } from 'next-auth'
import { authOptions } from '@/lib/auth'
import { redirect } from 'next/navigation'

export default async function AccountPage() {
  const session = await getServerSession(authOptions)
  if (!session) redirect('/login')
  const email = session.user?.email ?? ''
  const base = process.env.BACKEND_BASE_URL as string
  const subRes = await fetch(`${base}/api/subscription`, {
    headers: { 'x-user-email': email },
    cache: 'no-store'
  })
  const data = await subRes.json().catch(() => ({ plan: null, status: 'inactive' }))
  return (
    <div className="container py-12 max-w-3xl">
      <h2 className="h2">Account</h2>
      <div className="card p-6 mt-6">
        <div className="grid gap-2">
          <div>Email, {email}</div>
          <div>Plan, {data.plan ?? 'Free'}</div>
          <div>Status, {data.status ?? 'inactive'}</div>
        </div>
        <form action={`${base}/api/checkout/create`} method="POST" className="mt-6">
          <input type="hidden" name="email" value={email} />
          <button className="btn-primary">Upgrade</button>
        </form>
      </div>
      <div className="grid md:grid-cols-2 gap-4 mt-6">
        <HelpBot />
        <GriefBot />
      </div>
    </div>
  )
}

