// -----------------------------
// FILE: web/app/activity/page.tsx
// -----------------------------
import { getServerSession } from 'next-auth'
import { authOptions } from '@/lib/auth'
import { redirect } from 'next/navigation'

export default async function Page() {
  const session = await getServerSession(authOptions)
  if (!session) redirect('/login')
  const base = process.env.BACKEND_BASE_URL as string
  const res = await fetch(`${base}/api/activity`, { headers: { 'x-user-email': session.user?.email || '' }, cache: 'no-store' })
  const data = await res.json().catch(() => ({ items: [] }))
  return (
    <div className="container py-12 max-w-3xl">
      <h1 className="h1">Activity</h1>
      <ul className="mt-6 grid gap-2">
        {(data.items || []).map((it: any, i: number) => (
          <li key={i} className="card p-4">{it.text}</li>
        ))}
      </ul>
    </div>
  )
}

