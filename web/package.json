import { notFound } from 'next/navigation'

const rules: Record<string, any> = {
  CA: { min_age: 18, witnesses: 2, notarization_required: false, holographic_allowed: true, self_proving_affidavit: true, reviewed_at: '2025-08-25', version: 'v20250825' }
}

export default function Page({ params }: { params: { state: string } }) {
  const code = params.state.toUpperCase()
  const r = rules[code]
  if (!r) return notFound()
  return (
    <main className="container py-16 max-w-3xl">
      <h1 className="h1">{code} requirements</h1>
      <div className="mt-4 card p-6">
        <div>Reviewed, {r.reviewed_at} • Version, {r.version}</div>
        <ul className="mt-3 list-disc pl-6 text-slate-700 space-y-1">
          <li>Minimum age, {r.min_age}</li>
          <li>Witnesses, {r.witnesses}</li>
          <li>Notarization required, {String(r.notarization_required)}</li>
          <li>Self-proving affidavit, {String(r.self_proving_affidavit)}</li>
          <li>Holographic allowed, {String(r.holographic_allowed)}</li>
        </ul>
      </div>
    </main>
  )
}

